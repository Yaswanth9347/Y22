rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: tasks
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, length 1-100)
    //   - description: string (optional, length 0-1000)
    //   - status: string (required, enum: 'todo', 'inprogress', 'done')
    //   - priority: string (required, enum: 'low', 'medium', 'high')
    //   - createdAt: timestamp (required, immutable)
    //   - userId: string (required, immutable, must match auth.uid)
    //   - sprintId: string (optional, length 0-100)
    //
    // Collection: sprints
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, length 1-100)
    //   - startDate: timestamp (optional)
    //   - endDate: timestamp (optional)
    //   - status: string (required, enum: 'future', 'active', 'closed')
    //   - userId: string (required, immutable, must match auth.uid)
    //   - createdAt: timestamp (required, immutable)
    //   - totalTasks: number (optional)
    //   - completedTasks: number (optional)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == null ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // Domain Validators
    function isValidTask(data) {
      return hasOnlyAllowedFields(['title', 'description', 'status', 'priority', 'createdAt', 'userId', 'sprintId']) &&
             validStringLength('title', 1, 100) &&
             isValidOptionalString('description', 0, 1000) &&
             isValidOptionalString('sprintId', 0, 100) &&
             validStringLength('status', 1, 50) &&
             data.priority in ['low', 'medium', 'high'] &&
             data.createdAt is timestamp &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 50;
    }

    function isValidSprint(data) {
      return hasOnlyAllowedFields(['name', 'startDate', 'endDate', 'status', 'userId', 'createdAt', 'totalTasks', 'completedTasks']) &&
             validStringLength('name', 1, 100) &&
             data.status in ['future', 'active', 'closed'] &&
             (!('startDate' in data) || data.startDate == null || data.startDate is timestamp) &&
             (!('endDate' in data) || data.endDate == null || data.endDate is timestamp) &&
             (!('totalTasks' in data) || data.totalTasks is number) &&
             (!('completedTasks' in data) || data.completedTasks is number) &&
             data.createdAt is timestamp &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 50;
    }

    function isValidColumn(data) {
      return hasOnlyAllowedFields(['name', 'order', 'userId', 'createdAt']) &&
             validStringLength('name', 1, 50) &&
             data.order is number &&
             data.createdAt is timestamp &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 50;
    }

    function isValidActivity(data) {
      return hasOnlyAllowedFields(['taskId', 'userId', 'userName', 'type', 'content', 'createdAt']) &&
             validStringLength('taskId', 1, 100) &&
             isValidOptionalString('userName', 1, 100) &&
             data.type in ['comment', 'system'] &&
             validStringLength('content', 1, 2000) &&
             data.createdAt is timestamp &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 50;
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() &&
                    hasRequiredFields(['title', 'status', 'priority', 'createdAt', 'userId']) &&
                    isValidTask(request.resource.data) &&
                    uidUnchanged();
      allow update: if isDocOwner() &&
                    isValidTask(request.resource.data) &&
                    uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /sprints/{sprintId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() &&
                    hasRequiredFields(['name', 'status', 'userId', 'createdAt']) &&
                    isValidSprint(request.resource.data) &&
                    uidUnchanged();
      allow update: if isDocOwner() &&
                    isValidSprint(request.resource.data) &&
                    uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /columns/{columnId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() &&
                    hasRequiredFields(['name', 'order', 'userId', 'createdAt']) &&
                    isValidColumn(request.resource.data) &&
                    uidUnchanged();
      allow update: if isDocOwner() &&
                    isValidColumn(request.resource.data) &&
                    uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /activities/{activityId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() &&
                    hasRequiredFields(['taskId', 'userId', 'type', 'content', 'createdAt']) &&
                    isValidActivity(request.resource.data) &&
                    uidUnchanged();
      allow update: if isDocOwner() &&
                    isValidActivity(request.resource.data) &&
                    uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }
  }
}
