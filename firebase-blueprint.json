{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A single task in the project management system",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the task" },
        "description": { "type": "string", "description": "Optional description" },
        "status": { "type": "string", "description": "Current status/column of the task" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"], "description": "Priority level" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "userId": { "type": "string", "description": "Owner of the task" },
        "sprintId": { "type": "string", "description": "ID of the sprint this task belongs to" }
      },
      "required": ["title", "status", "priority", "createdAt", "userId"]
    },
    "Sprint": {
      "title": "Sprint",
      "description": "A time-boxed period for completing tasks",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the sprint" },
        "startDate": { "type": "string", "format": "date-time", "description": "Start date of the sprint" },
        "endDate": { "type": "string", "format": "date-time", "description": "End date of the sprint" },
        "status": { "type": "string", "enum": ["future", "active", "closed"], "description": "Current status of the sprint" },
        "userId": { "type": "string", "description": "Owner of the sprint" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "totalTasks": { "type": "number", "description": "Total tasks at closing" },
        "completedTasks": { "type": "number", "description": "Completed tasks at closing" }
      },
      "required": ["name", "status", "userId", "createdAt"]
    },
    "Column": {
      "title": "Column",
      "description": "A custom column for the board",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the column" },
        "order": { "type": "number", "description": "Order of the column on the board" },
        "userId": { "type": "string", "description": "Owner of the column" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "order", "userId", "createdAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "An activity or comment on a task",
      "type": "object",
      "properties": {
        "taskId": { "type": "string", "description": "ID of the task" },
        "userId": { "type": "string", "description": "User who performed the activity" },
        "userName": { "type": "string", "description": "Name of the user who performed the activity" },
        "type": { "type": "string", "enum": ["comment", "system"], "description": "Type of activity" },
        "content": { "type": "string", "description": "Content of the comment or system message" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["taskId", "userId", "type", "content", "createdAt"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Collection of all tasks"
    },
    "/sprints/{sprintId}": {
      "schema": { "$ref": "#/entities/Sprint" },
      "description": "Collection of all sprints"
    },
    "/columns/{columnId}": {
      "schema": { "$ref": "#/entities/Column" },
      "description": "Collection of board columns"
    },
    "/activities/{activityId}": {
      "schema": { "$ref": "#/entities/Activity" },
      "description": "Collection of task activities and comments"
    }
  }
}
